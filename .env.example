# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ──────────────────────────────────────────────
# Database (MySQL — Aiven free tier)
# ──────────────────────────────────────────────
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASSWORD=your-aiven-password
DB_NAME=defaultdb

# Path to Aiven CA certificate (local dev)
DB_SSL_CA=./ca.pem

# OR: paste the full CA cert content here (for Render deployment)
# DB_SSL_CA_CONTENT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ──────────────────────────────────────────────
# CORS — set to your Netlify frontend URL
# ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200
