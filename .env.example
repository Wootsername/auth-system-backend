# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ──────────────────────────────────────────────
# Database (MySQL — Railway / General)
# ──────────────────────────────────────────────
DB_HOST=your-database-host.railway.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-database-password
DB_NAME=railway
DB_SSL=true

# SSL options (if using CA certificates instead of DB_SSL=true)
# DB_SSL_CA=./ca.pem
# DB_SSL_CA_CONTENT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ──────────────────────────────────────────────
# CORS — set to your Netlify frontend URL
# ──────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200
